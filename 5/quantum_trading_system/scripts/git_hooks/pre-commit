#!/bin/bash
# 量子量化平台 - Git pre-commit hook
# 在每次提交前自动运行测试

echo "================================================"
echo "量子量化平台 - pre-commit 检查"
echo "================================================"

# 运行测试
echo "运行策略测试..."
python tests/run_tests.py

if [ $? -ne 0 ]; then
    echo "❌ 测试失败，请修复后再提交"
    exit 1
fi

echo "✅ 测试通过！"
exit 0
